{
    "author": "overcuriousity@posteo.org (fork of ericlmccormick/Pebble_7_day_ICS_Calendar)",
    "dependencies": {
        "pebble-clay": "^1.0.4"
    },
    "devDependencies": {
        "ical-expander": "1.1.2",
        "ical.js": "1.5.0"
    },
    "scripts": {
        "vendor": "cp node_modules/ical.js/build/ical.min.js src/pkjs/lib/ical.min.js && cp node_modules/ical-expander/zones-compiled.json src/pkjs/lib/zones-compiled.json",
        "test": "node test/parse.test.js test/fixture.ics",
        "build": "pebble build && (cd build && zip -dq caldav-calendar.pbw pebble-js-app.js.map || true)"
    },
    "keywords": [],
    "name": "caldav-calendar",
    "pebble": {
        "capabilities": [
            "configurable"
        ],
        "displayName": "CalDAV Calendar",
        "enableMultiJS": true,
        "messageKeys": [
            "TOTAL_EVENTS",
            "CHUNK_INDEX",
            "EVENT_DATA",
            "TIME_FORMAT",
            "ICAL_URL_1",
            "ICAL_URL_2",
            "ICAL_URL_3",
            "ICAL_URL_4",
            "ICAL_DAYS",
            "ICAL_SYNC_INTERVAL"
        ],
        "projectType": "native",
        "resources": {
            "media": []
        },
        "sdkVersion": "3",
        "targetPlatforms": [
            "emery"
        ],
        "uuid": "a1799c66-ef8e-4353-a875-7e218e1526e5",
        "watchapp": {
            "watchface": false
        }
    },
    "version": "1.0.0"
}
